{
  "name": "another-graphql-ide",
  "version": "0.0.1",
  "private": true,
  "description": "Just another GraphQL IDE",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "types": "turbo run types",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "preview": "pnpm --filter foundry dev",
    "preview:build": "pnpm --filter foundry build",
    "preview:serve": "pnpm --filter foundry preview",
    "prettier:check": "pnpm prettier --check --cache ./",
    "prettier:write": "pnpm prettier --write --cache ./"
  },
  "keywords": [
    "graphql",
    "ide"
  ],
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": "24.x",
    "pnpm": "10.x"
  },
  "dependencies": {
    "@types/node": "24.13.3",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "eslint": "catalog:",
    "graphql": "catalog:",
    "prettier": "3.9.5",
    "react": "catalog:",
    "react-dom": "catalog:",
    "turbo": "2.10.5",
    "typescript": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "graphql": "16.14.2"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint-plugin-react>eslint": "10",
        "eslint-plugin-jsx-a11y>eslint": "10"
      }
    }
  }
}
